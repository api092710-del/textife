generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model users {
  id              String   @id @db.Uuid
  fullName        String
  username        String   @unique
  email           String   @unique
  dateOfBirth     String?
  password        String
  role            String   @default("USER")
  plan            String   @default("FREE")
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  isBanned        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  analytics       analytics[]
  bot_instances   bot_instances[]
  chat_sessions   chat_sessions[]
  payments        payments[]
  subscriptions   subscriptions[]
}

model analytics {
  id              String   @id
  user_id         String   @db.Uuid
  date            DateTime @default(now())
  messagesHandled Int      @default(0)
  leadsCaptures   Int      @default(0)
  revenueEst      Float    @default(0)
  apiCalls        Int      @default(0)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model bot_instances {
  id            String   @id
  user_id       String   @db.Uuid
  name          String
  phoneNumber   String?
  status        String   @default("INACTIVE")
  config        String?
  totalReplies  Int      @default(0)
  leadsCaptures Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model chat_sessions {
  id        String   @id
  user_id   String   @db.Uuid
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime

  users         users           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chat_messages chat_messages[]
}

model chat_messages {
  id        String   @id
  sessionId String
  role      String
  content   String
  tokens    Int?
  createdAt DateTime @default(now())

  chat_sessions chat_sessions @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model payments {
  id         String   @id
  user_id    String   @db.Uuid
  provider   String
  externalId String?
  amount     Float
  currency   String   @default("USD")
  status     String   @default("PENDING")
  plan       String
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model subscriptions {
  id         String   @id
  user_id    String   @db.Uuid
  plan       String
  status     String   @default("ACTIVE")
  provider   String
  externalId String?
  amount     Float
  currency   String   @default("USD")
  startDate  DateTime @default(now())
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model templates {
  id          String   @id
  user_id     String?  @db.Uuid
  title       String
  description String?
  category    String
  content     String
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model scam_signals {
  id          String   @id
  source      String
  title       String
  description String?
  url         String?
  platform    String?
  region      String   @default("Global")
  rawData     String?
  hash        String?  @unique
  createdAt   DateTime @default(now())
}

model security_alerts {
  id          String   @id
  date        String
  alerts      String
  tip         String?
  signalCount Int      @default(0)
  createdAt   DateTime @default(now())
}
