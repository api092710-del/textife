generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model analytics {
  id              String   @id
  userId          String
  date            DateTime @default(now())
  messagesHandled Int      @default(0)
  leadsCaptures   Int      @default(0)
  revenueEst      Float    @default(0)
  apiCalls        Int      @default(0)
  users           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bot_instances {
  id            String   @id
  userId        String
  name          String
  phoneNumber   String?
  status        String   @default("INACTIVE")
  config        String?
  totalReplies  Int      @default(0)
  leadsCaptures Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  users         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_messages {
  id            String        @id
  sessionId     String
  role          String
  content       String
  tokens        Int?
  createdAt     DateTime      @default(now())
  chat_sessions chat_sessions @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model chat_sessions {
  id            String          @id
  userId        String
  title         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  chat_messages chat_messages[]
  users         users           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id         String   @id
  userId     String
  provider   String
  externalId String?
  amount     Float
  currency   String   @default("USD")
  status     String   @default("PENDING")
  plan       String
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model scam_signals {
  id          String   @id
  source      String
  title       String
  description String?
  url         String?
  platform    String?
  region      String   @default("Global")
  rawData     String?
  hash        String?  @unique
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([source])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model security_alerts {
  id          String   @id
  date        String
  alerts      String
  tip         String?
  signalCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([date])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subscriptions {
  id         String    @id
  userId     String
  plan       String
  status     String    @default("ACTIVE")
  provider   String
  externalId String?
  amount     Float
  currency   String    @default("USD")
  startDate  DateTime  @default(now())
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  users      users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model templates {
  id          String   @id
  userId      String?
  title       String
  description String?
  category    String
  content     String
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id              String          @id
  fullName        String
  username        String          @unique
  email           String          @unique
  dateOfBirth     String?
  password        String
  role            String          @default("USER")
  plan            String          @default("FREE")
  isEmailVerified Boolean         @default(true)
  isActive        Boolean         @default(true)
  isBanned        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  analytics       analytics[]
  bot_instances   bot_instances[]
  chat_sessions   chat_sessions[]
  payments        payments[]
  subscriptions   subscriptions[]
}
